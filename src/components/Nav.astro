---
// Sticky top nav. Links are anchors on the home page; on detail pages they point back home.
interface Props {
  onHome?: boolean;
}
const { onHome = false } = Astro.props;
const href = (anchor: string) => (onHome ? `#${anchor}` : `/#${anchor}`);
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-bold text-[var(--color-text)]">
      <span class="text-[var(--color-accent)]">~/</span>haochen.tong
    </a>
    <ul class="hidden gap-6 font-mono text-sm text-[var(--color-muted)] sm:flex">
      <li><a href={href('work')} class="hover:text-[var(--color-accent)]">work</a></li>
      <li><a href={href('experience')} class="hover:text-[var(--color-accent)]">experience</a></li>
      <li><a href={href('skills')} class="hover:text-[var(--color-accent)]">skills</a></li>
      <li><a href={href('contact')} class="hover:text-[var(--color-accent)]">contact</a></li>
    </ul>
  </nav>
</header>
