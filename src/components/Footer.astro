---
const links = {
  github: 'https://github.com/haochentSC',
  linkedin: 'https://linkedin.com/in/haochent',
  email: 'mailto:tonghaochen77@gmail.com',
};
const year = new Date().getFullYear();
---

<section id="contact" class="grid-bg">
  <div class="mx-auto max-w-5xl px-6 py-20">
    <p class="section-label">// contact</p>
    <h2 class="mt-4 font-mono text-2xl font-bold text-[var(--color-text)]">
      Let's build something.<span class="cursor"></span>
    </h2>
    <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--color-muted)]">
      Open to SWE and AI-infra roles. The fastest way to reach me is email.
    </p>
    <div class="mt-6 flex flex-wrap gap-4 font-mono text-sm">
      <a href={links.email} class="text-[var(--color-accent)] hover:underline">tonghaochen77@gmail.com</a>
      <span class="text-[var(--color-faint)]">·</span>
      <a href={links.github} class="text-[var(--color-muted)] hover:text-[var(--color-accent)]">github</a>
      <span class="text-[var(--color-faint)]">·</span>
      <a href={links.linkedin} class="text-[var(--color-muted)] hover:text-[var(--color-accent)]">linkedin</a>
    </div>
  </div>
</section>

<footer class="border-t border-[var(--color-border)]">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-2 px-6 py-6 font-mono text-xs text-[var(--color-faint)]"
  >
    <span>© {year} Haochen Tong</span>
    <span>built with Astro · <a href="https://github.com/haochentSC/haochentSC.github.io" class="hover:text-[var(--color-accent)]">source</a></span>
  </div>
</footer>
