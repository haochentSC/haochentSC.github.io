---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MetricBadge from '../components/MetricBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, tagline, role, period, status, stack, metrics, links } = project.data;
---

<Base title={`${title} — Haochen Tong`} description={tagline}>
  <Nav onHome={false} />
  <main class="mx-auto max-w-3xl px-6 py-16">
    <a href="/#work" class="font-mono text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">
      ← back to work
    </a>

    <header class="mt-6 border-b border-[var(--color-border)] pb-8">
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="font-mono text-3xl font-bold text-[var(--color-text)]">{title}</h1>
        <span class="rounded border border-[var(--color-border-strong)] px-2 py-0.5 font-mono text-xs text-[var(--color-accent)]">
          {status}
        </span>
      </div>
      <p class="mt-3 text-lg text-[var(--color-muted)]">{tagline}</p>
      <p class="mt-2 font-mono text-sm text-[var(--color-faint)]">{role} · {period}</p>

      {
        metrics.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-3">
            {metrics.map((m) => (
              <MetricBadge value={m.value} label={m.label} />
            ))}
          </div>
        )
      }

      <div class="mt-6 flex flex-wrap gap-4 font-mono text-sm">
        {
          links.live && (
            <a
              href={links.live}
              class="rounded border border-[var(--color-border-strong)] px-4 py-2 text-[var(--color-text)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
            >
              live ↗
            </a>
          )
        }
        {
          links.github && (
            <a
              href={links.github}
              class="rounded border border-[var(--color-border-strong)] px-4 py-2 text-[var(--color-text)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
            >
              github ↗
            </a>
          )
        }
      </div>
    </header>

    <article
      class="prose-portfolio mt-8 max-w-none text-[var(--color-muted)] leading-relaxed"
    >
      <slot />
    </article>

    <div class="mt-10 border-t border-[var(--color-border)] pt-6">
      <p class="section-label">// stack</p>
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {
          stack.map((tech) => (
            <li class="rounded bg-[var(--color-surface)] px-2.5 py-1 font-mono text-xs text-[var(--color-muted)]">
              {tech}
            </li>
          ))
        }
      </ul>
    </div>
  </main>
  <Footer />
</Base>

<style is:global>
  /* Minimal typography for the Markdown body of a project page. */
  .prose-portfolio h2 {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-portfolio h2::before {
    content: '// ';
    color: var(--color-accent);
  }
  .prose-portfolio h3 {
    font-family: var(--font-mono);
    color: var(--color-cyan);
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-portfolio p { margin: 0.75rem 0; }
  .prose-portfolio ul { list-style: none; margin: 0.75rem 0; padding: 0; }
  .prose-portfolio li { padding-left: 1.25rem; position: relative; margin: 0.4rem 0; }
  .prose-portfolio li::before {
    content: '▸';
    color: var(--color-accent);
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
  }
  .prose-portfolio a { color: var(--color-accent); text-decoration: underline; }
  .prose-portfolio code {
    font-family: var(--font-mono);
    background: var(--color-surface);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    color: var(--color-cyan);
  }
  .prose-portfolio strong { color: var(--color-text); }
  .prose-portfolio img { border-radius: 0.5rem; border: 1px solid var(--color-border); }
  .prose-portfolio figure {
    margin: 1.5rem 0;
  }
  .prose-portfolio figure img {
    display: block;
    width: 100%;
    background: var(--color-surface);
  }
  .prose-portfolio figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-faint);
    text-align: center;
  }
  .prose-portfolio figcaption::before {
    content: 'fig. ';
    color: var(--color-accent);
  }
</style>
