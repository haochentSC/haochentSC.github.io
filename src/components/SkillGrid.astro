---
// Grouped skills. Trimmed from the master resume's comprehensive table to the strongest signal.
const groups: { name: string; skills: string[] }[] = [
  { name: 'Languages', skills: ['Python', 'Go', 'Java', 'C/C++', 'TypeScript', 'SQL'] },
  { name: 'Backend & APIs', skills: ['FastAPI', 'Flask', 'REST', 'Celery', 'JWT', 'async/await'] },
  { name: 'GenAI / RAG', skills: ['vLLM', 'RAG', 'multimodal RAG', 'BM25', 'RRF', 'CLIP', 'Qwen3-Omni'] },
  { name: 'Distributed Systems', skills: ['gRPC/Protobuf', 'consistent hashing', 'etcd', 'replication', 'chaos testing'] },
  { name: 'Infra & DevOps', skills: ['Docker', 'AWS', 'Terraform', 'Railway', 'Vercel', 'CI/CD'] },
  { name: 'Data & Storage', skills: ['PostgreSQL', 'Redis', 'Firebase', 'JSONB'] },
  { name: 'ML / Simulation', skills: ['PyTorch', 'Gymnasium', 'MuJoCo', 'VAE', 'PPO'] },
  { name: 'Observability & Testing', skills: ['Prometheus', 'CloudWatch', 'pytest', 'benchmark-driven'] },
];
---

<section id="skills" class="border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-5xl px-6 py-20">
    <p class="section-label">// skills</p>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        groups.map((group) => (
          <div>
            <h3 class="font-mono text-sm font-bold text-[var(--color-cyan)]">{group.name}</h3>
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {group.skills.map((skill) => (
                <li class="rounded border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 py-1 font-mono text-xs text-[var(--color-muted)]">
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
